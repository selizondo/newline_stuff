# Copy this file to .env and fill in your credentials.
# .env is gitignored — never commit real API keys.

# ── Generation model (Phase 1) ────────────────────────────────────────────
# Used for producing Q&A pairs — quality and creativity matter here.
# OpenAI (default):
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-your-openai-key-here
LLM_MODEL=llama-3.1-8b-instant

# ── Judge model (Phases 3, 4, 7) ─────────────────────────────────────────
# Used for binary 0/1 evaluation — instruction following matters more than size.
# Defaults to LLM_MODEL when unset (same model for both).
#
# Recommended: run locally with Ollama to save cost on bulk eval calls.
#   ollama pull qwen2.5:3b
LLM_JUDGE_MODEL=qwen2.5:3b
LLM_JUDGE_BASE_URL=http://localhost:11434/v1
LLM_JUDGE_API_KEY=ollama

# ── Rate limiting ─────────────────────────────────────────────────────────
# Seconds to wait between LLM calls. Applies to both generation and judge clients.
# 0.5 works for direct OpenAI; local Ollama can use 0.0.
LLM_RATE_LIMIT_DELAY=0.5
LLM_JUDGE_RATE_LIMIT_DELAY=0.0
